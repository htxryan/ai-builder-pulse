# AI Builder Pulse — environment variables.
#
# Copy this file to `.env` for local development and fill in the secrets.
# Never commit `.env`. GitHub Actions uses repo Secrets, not this file.
#
# Variables are grouped by scope: (R)equired for a real publish, (O)ptional
# (defaulted or feature-flagged), and (S)ecrets.

# --- Mode & entry point -----------------------------------------------------

# (O) Pipeline mode. `daily` runs the daily pipeline (default); `weekly` runs
# the 7-day rollup over `issues/*/items.json`.
MODE=daily

# (O) `1` = skip Buttondown POST, archive write, and commit. Bypasses the
# daily S-03 sentinel check too so operators can preview an already-sent day.
# Leave unset (or `0`) for a real publish.
DRY_RUN=0

# --- Curator (Claude) -------------------------------------------------------

# (S) Claude API key. Required when `CURATOR=claude`. Unused under `mock`.
ANTHROPIC_API_KEY=sk-ant-...

# (O) Which curator implementation to use. `mock` (default) bypasses the API
# and returns deterministic scored items — useful for dev and CI. `claude`
# calls the real Anthropic API.
CURATOR=mock

# (O) Max RawItems per Claude call. Default 50. Larger chunks reduce
# per-call overhead but increase the risk of a single retry burning budget.
CURATOR_CHUNK_THRESHOLD=50

# (O) Hard ceiling in USD for a single `curate()` run. If estimated cost
# exceeds this, the run aborts with CostCeilingError. Default 1.0.
CURATOR_MAX_USD=1.0

# (O) DEV/DEMO ONLY. Override the pinned curator model id. Applies to BOTH
# the direct-SDK path (`anthropicClient.ts`) and the DeepAgents path
# (`deepagent/adapter.ts`) so backend behavior stays consistent. Intended for
# alt-provider routing (pair with `ANTHROPIC_BASE_URL`, e.g. OpenRouter with
# `anthropic/claude-sonnet-4.5`), cost-constrained demos, or A/B-testing a
# prior model. Prod MUST leave this unset — the prompt-cache keys and
# consistency guarantees assume the `MODEL_PIN` constant in `prompt.ts`.
# CURATOR_MODEL_OVERRIDE=

# --- Publisher (Buttondown) -------------------------------------------------

# (S) Buttondown publish key. Required for a real daily or weekly publish.
BUTTONDOWN_API_KEY=bd_...

# --- Reddit collector -------------------------------------------------------

# (S) Reddit OAuth script-app credentials. Required for the authenticated
# path. Leave blank to force the fallback path via `REDDIT_FALLBACK_PUBLIC=1`.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# (O) `1` = use the unauthenticated JSON endpoint instead of OAuth. Less
# reliable under rate limits but avoids needing a Reddit app.
REDDIT_FALLBACK_PUBLIC=0

# (O) `1` = skip the Reddit collector entirely. The source floor (S-05) still
# applies to the remaining collectors.
REDDIT_DISABLED=0

# --- Pipeline thresholds ----------------------------------------------------

# (O) Minimum kept ScoredItems to publish (S-02). Below this, the day is
# skipped unless ARCHIVES_FALLBACK=1. Default 5.
MIN_ITEMS_TO_PUBLISH=5

# (O) Minimum successful collectors that must contribute post-filter items
# (S-05). Default 2. Below this, the day is skipped unless
# ARCHIVES_FALLBACK=1.
MIN_SOURCES=2

# (O) `1` = opt into the "From the archives" re-publish path when the day
# would otherwise be silent. Off by default — see README "Silence SLA".
ARCHIVES_FALLBACK=0

# (O) Minimum archive days (of the last 7) required before the weekly rollup
# will publish. Default 7. Clamped to [1, 7]; invalid values fall back to the
# default with a ::warning::. Below the threshold the weekly exits
# `insufficient_days`, logs, and returns 0 (not a failure). Intended use:
# prevent a stunted "weekly" from firing on the first Monday after a fresh
# deployment.
MIN_DAYS_FOR_WEEKLY=7

# (O) Global orchestrator timeout in ms. Default 720000 (12 min), leaving
# a 3-min buffer under the GHA 15-min job cap.
ORCHESTRATOR_TIMEOUT_MS=720000

# --- Feature flags ----------------------------------------------------------

# (O) `1` = flip the Twitter collector to report "twitter not implemented in
# v1" instead of "ENABLE_TWITTER not set". Has no functional effect; Twitter
# is a stub until a funded API plan is in place.
ENABLE_TWITTER=0

# (O) `1` = use mock collectors (no network). Useful for local dev. Does not
# affect the curator selection.
USE_MOCK_COLLECTORS=0

# --- Observability ----------------------------------------------------------

# (O) `1` = emit `debug`-level log lines. Off by default.
DEBUG=0

# --- Workflow-provided (do not set manually) --------------------------------

# Set by daily.yml / weekly.yml pre-flight when the remote sentinel is already
# present for this period. Causes src/index.ts to exit 0 before any side
# effects. Do NOT set these by hand for a real run.
# SKIP_RUN=
# SKIP_RUN_REASON=

# Set by GitHub Actions. Path to the job summary file. Used by runSummary.ts.
# GITHUB_STEP_SUMMARY=
